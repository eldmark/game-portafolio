generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  description    String
  architecture   String
  challenges     Json
  stack          Json
  stackReasoning String         @map("stack_reasoning")
  githubUrl      String?        @map("github_url")
  liveUrl        String?        @map("live_url")
  thumbnail      String?
  gifDemo        String?        @map("gif_demo")
  featured       Boolean        @default(false)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  media          ProjectMedia[]
  posts          Post[]

  @@map("projects")
}

model ProjectMedia {
  id         String  @id @default(cuid())
  projectId  String  @map("project_id")
  type       String
  url        String
  alt        String
  orderIndex Int     @default(0) @map("order_index")
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_media")
}

model Skill {
  id         String   @id @default(cuid())
  name       String
  category   String
  icon       String?
  level      Int
  reasoning  String
  appliedIn  Json     @map("applied_in")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("skills")
}

model Experience {
  id           String   @id @default(cuid())
  company      String
  role         String
  description  String
  startDate    DateTime @map("start_date")
  endDate      DateTime? @map("end_date")
  technologies Json
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("experiences")
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model UserVisit {
  id            String        @id @default(cuid())
  sessionId     String        @unique @map("session_id")
  recruiterMode Boolean       @default(false) @map("recruiter_mode")
  duration      Int?
  country       String?
  device        String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  dialogueLogs  DialogueLog[]

  @@map("user_visits")
}

model DialogueLog {
  id          String    @id @default(cuid())
  sessionId   String    @map("session_id")
  dialogueKey String    @map("dialogue_key")
  createdAt   DateTime  @default(now()) @map("created_at")
  visit        UserVisit @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@map("dialogue_logs")
}

model Goal {
  id          String    @id @default(cuid())
  title       String
  description String
  category    String
  status      String    @default("planned") // "planned" | "in_progress" | "done"
  targetDate  DateTime? @map("target_date")
  orderIndex  Int       @default(0) @map("order_index")
  trophyId    String?   @map("trophy_id")
  trophy      Trophy?   @relation(fields: [trophyId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("goals")
}

model Trophy {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String?
  category    String
  dateEarned  DateTime @map("date_earned")
  proofUrl    String?  @map("proof_url")
  goals       Goal[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("trophies")
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  body        String // markdown
  projectId   String?  @map("project_id")
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  publishedAt DateTime @default(now()) @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("posts")
}

model DevlogEntry {
  id          String   @id @default(cuid())
  repo        String // e.g. "eldmark/db_barbershop"
  branch      String
  commitSha   String   @map("commit_sha")
  commitUrl   String   @map("commit_url")
  message     String // generated phrase, e.g. "Pushed 3 commits to db_barbershop"
  commitCount Int      @default(1) @map("commit_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("devlog_entries")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}
